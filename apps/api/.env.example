# =============================================================================
# apps/api — .env.example
# Copy to .env. Validated by Zod at boot — the process crashes if values are
# missing or malformed. See src/common/config/env.schema.ts.
# =============================================================================

NODE_ENV=development

# ---- HTTP ----
API_PORT=3001
API_HOST=0.0.0.0
API_PUBLIC_URL=http://localhost:3001

# Comma-separated list of allowed origins. Empty in prod = no CORS.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ---- Database ----
DATABASE_URL=postgresql://app:app@localhost:5432/app?schema=public

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- Auth ----
# Generate: openssl rand -base64 48
JWT_ACCESS_SECRET=replace-me-with-strong-random-secret-min-32-bytes
JWT_REFRESH_SECRET=replace-me-with-different-strong-random-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ---- Logging ----
# trace | debug | info | warn | error | fatal
LOG_LEVEL=debug
# Pretty-print in dev; structured JSON in prod
LOG_PRETTY=true

# ---- Rate limiting (token bucket) ----
RATE_LIMIT_GLOBAL_PER_MIN=600
RATE_LIMIT_AUTH_PER_MIN=20

# ---- Observability (optional in dev) ----
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=project-api
SENTRY_DSN=

# ---- Google OAuth variables ----
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# Redirect routes after the handshake finishes
FRONTEND_DASHBOARD_URL="http://localhost:3000"
FRONTEND_ONBOARDING_URL="http://localhost:3000/onboarding"

# Email service RESEND - required for sending emails, password reset flows, etc.
RESEND_API_KEY= your-resend-api-key
EMAIL_FROM_ADDRESS="Auth Test <onboarding@resend.dev>"

# Email verification config
MAX_VERIFICATION_ATTEMPTS=5
MAX_VERIFICATION_CODE_TTL_MINUTES=15
EMAIL_RATE_LIMIT_MAX_PER_HOUR=10
RATE_LIMITER_DURATION=60