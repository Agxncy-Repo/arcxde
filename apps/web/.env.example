# =============================================================================
# apps/web — .env.example
# Copy to .env.local for local dev. NEXT_PUBLIC_* vars are exposed to the browser.
# =============================================================================

# API base URL. In dev, this is your local API. In prod, your real API host.
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# Server-side only — used by RSC / route handlers / server actions
# If your API has internal-only endpoints reachable on a private network in prod,
# you can route server-side calls through INTERNAL_API_URL.
INTERNAL_API_URL=http://localhost:3001/api/v1
