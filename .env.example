# =============================================================================
# arcxde — root .env.example
# Copy to .env. Real values come from the team password manager / secrets store.
# Per-app overrides live in apps/*/.env.example.
# =============================================================================

NODE_ENV=development

# ---- Database (Postgres) ----
# Local docker-compose default. Production value is fetched from secret manager.
DATABASE_URL=postgresql://app:app@localhost:5432/app?schema=public

# ---- Redis (BullMQ, caching, rate limiting) ----
REDIS_URL=redis://localhost:6379

# ---- API server ----
API_PORT=3001
API_HOST=0.0.0.0
API_PUBLIC_URL=http://localhost:3001
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ---- Auth ----
# 32+ bytes, base64-encoded. Generate: openssl rand -base64 48
JWT_ACCESS_SECRET=replace-me-with-strong-random-secret-min-32-bytes
JWT_REFRESH_SECRET=replace-me-with-different-strong-random-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ---- Logging ----
LOG_LEVEL=debug
LOG_PRETTY=true

# ---- Observability ----
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=project-api
SENTRY_DSN=
